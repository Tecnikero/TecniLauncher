<Window x:Class="TecniLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TecniLauncher" 
        Height="650" Width="1000"
        MinHeight="600" MinWidth="900"  
        WindowStyle="None" 
        ResizeMode="CanResizeWithGrip" 
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen" xmlns:md="clr-namespace:MdXaml;assembly=MdXaml">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="0"  
            ResizeBorderThickness="5" 
            CornerRadius="0" 
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="ColorAccent" Color="#4facfe"/>
        <SolidColorBrush x:Key="ColorAccentDim" Color="#334facfe"/>
        <SolidColorBrush x:Key="BgDark" Color="#0f2027"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#111625"/>
        <SolidColorBrush x:Key="BgCard" Color="#1E2328"/>
        <SolidColorBrush x:Key="BgInput" Color="#222222"/>
        <SolidColorBrush x:Key="TextMain" Color="White"/>
        <SolidColorBrush x:Key="TextSub" Color="#AAAAAA"/>

        <DrawingBrush x:Key="TechGridPattern" TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute" Opacity="0.03">
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="White" Thickness="0.5"/>
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="40,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,40" />
                            <EllipseGeometry Center="0,0" RadiusX="1" RadiusY="1"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#4facfe"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          Background="{TemplateBinding Background}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Grid.Column="2" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,25,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#252525" BorderThickness="1" BorderBrush="#4facfe" CornerRadius="6" Margin="0,2,0,0">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Background" Value="{StaticResource ColorAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="8" Padding="15,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{StaticResource ColorAccentDim}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource ColorAccent}"/>
                                <Setter TargetName="bdr" Property="BorderThickness" Value="2,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="12" Background="{StaticResource BgDark}" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
                    <Grid>
                        <Border BorderBrush="#22FFFFFF" BorderThickness="0,0,1,0" HorizontalAlignment="Right"/>

                        <StackPanel Margin="20">
                            <StackPanel Margin="0,10,0,40">
                                <TextBlock Text="TECNI" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="26" HorizontalAlignment="Center"/>
                                <TextBlock Text="LAUNCHER" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="26" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                                <Rectangle Height="2" Width="50" Fill="{StaticResource ColorAccent}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <RadioButton Content="{DynamicResource Menu_Events}" Style="{StaticResource MenuButtonStyle}" Height="50" Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,2" Click="MenuEventos_Click" IsChecked="True"/>
                            <RadioButton Content="{DynamicResource Menu_Play}" Style="{StaticResource MenuButtonStyle}" Click="MenuJugar_Click" Height="50" Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,2"/>
                            <RadioButton Content="{DynamicResource Menu_Profiles}" Style="{StaticResource MenuButtonStyle}" Height="50" Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,2" Click="MenuPerfiles_Click"/>
                            <RadioButton Content="{DynamicResource Menu_Mods}" Style="{StaticResource MenuButtonStyle}" Height="50" Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,2" Click="MenuMods_Click"/>
                            <RadioButton Content="{DynamicResource Menu_ModPacks}" Style="{StaticResource MenuButtonStyle}" Height="50" Foreground="{StaticResource TextMain}" FontSize="15" Margin="0,2" Click="MenuModpacks_Click"/>

                            <Rectangle Height="1" Fill="#22FFFFFF" Margin="10,20"/>

                            <RadioButton Content="{DynamicResource Menu_Settings}" Style="{StaticResource MenuButtonStyle}" Height="50" Foreground="{StaticResource TextSub}" FontSize="14" Click="MenuAjustes_Click"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Width="35" Height="35" Margin="5" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnDiscord_Click">
                                <Path Fill="{StaticResource TextMain}" Stretch="Uniform" Width="22" Height="22" 
                              Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1432-.1064.2868-.2132.4233-.3241a.0746.0746 0 00.0235-.0814c3.9204 1.7933 8.18 1.7933 12.0614 0a.0738.0738 0 00.024.0821c.1367.111.2803.2177.4233.3241a.076.076 0 01-.0077.1277 12.2946 12.2946 0 01-1.8722.8923.077.077 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6066 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0551c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419z"/>
                            </Button>

                            <Button Width="35" Height="35" Margin="5" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnGithub_Click">
                                <Path Fill="{StaticResource TextMain}" Stretch="Uniform" Width="22" Height="22"
                              Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.419-1.305.763-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                            </Button>
                        </StackPanel>

                        <TextBlock x:Name="TxtVersion" Text="v1.0.0" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10" Foreground="#444" FontSize="10"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Cursor="">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0f2027" Offset="0.0"/>
                            <GradientStop Color="#203a43" Offset="0.6"/>
                            <GradientStop Color="#2c5364" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <Rectangle Fill="{StaticResource TechGridPattern}" IsHitTestVisible="False"/>

                    <Grid VerticalAlignment="Top" Height="40" Background="Transparent" MouseLeftButtonDown="MoverVentana_MouseDown" Panel.ZIndex="100">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <Button Content="—" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" Click="Minimizar_Click"/>
                            <Button x:Name="btnMaximizar" Content="☐" Width="40" Height="30" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" Click="Maximizar_Click" FontSize="14"/>
                            <Button Content="✕" Width="40" Height="30" Background="Transparent" Foreground="#ff5f56" FontWeight="Bold" BorderThickness="0" Click="Cerrar_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Background="#44000000" CornerRadius="25" Padding="10,5" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,40,70,0" Panel.ZIndex="90">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="32" Height="32" Fill="#ccc" Margin="0,0,10,0" x:Name="imgAvatar" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock x:Name="txtUsuario" Text="{DynamicResource Login_NoSession}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                            <Button Content="{DynamicResource Btn_Login}" Margin="5,0,0,0" Background="{StaticResource ColorAccent}" Foreground="White" BorderThickness="5" Padding="15,5" Height="30" FontSize="11" FontWeight="Bold" Click="AbrirLogin_Click" Width="50">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Grid x:Name="VistaEventos" Visibility="Visible" Margin="40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,30">
                            <TextBlock Text="{DynamicResource Events_Header}" FontSize="12" FontWeight="Bold" Foreground="#3498db" HorizontalAlignment="Left"/>
                            <TextBlock Text="{DynamicResource Events_Active}" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="listaEventosUI">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1AFFFFFF" CornerRadius="15" Margin="10" Width="260" Padding="20">
                                            <StackPanel>
                                                <Ellipse Width="90" Height="90" HorizontalAlignment="Center" Margin="0,0,0,15">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding FotoUrl}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <TextBlock Text="{Binding Nombre}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                                                    <Border BorderBrush="#3498db" BorderThickness="1.5" CornerRadius="4" Padding="6,2">
                                                        <TextBlock Text="{DynamicResource Events_Ram}" Foreground="#3498db" FontSize="10" FontWeight="Black"/>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                                        <ComboBox ItemsSource="{Binding OpcionesRamGB}"
                                                                  SelectedItem="{Binding MemoriaRamGB, Mode=TwoWay}"
                                                                  Width="50" Height="25" Padding="5,0"
                                                                  VerticalContentAlignment="Center"
                                                                  Background="#202020" Foreground="White" BorderBrush="#444444">
                                                            <ComboBox.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="4"/>
                                                                </Style>
                                                            </ComboBox.Resources>
                                                        </ComboBox>
                                                        <TextBlock Text="{DynamicResource Events_GB}" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="10"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid Height="45">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="45"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0" Margin="0,0,5,0" Background="#5865F2" BorderThickness="0" 
                                                            ToolTip="Unirse al Discord" Tag="{Binding}" Click="BtnDiscordEvento_Click">
                                                        <Path Fill="White" Stretch="Uniform" Width="20" Height="20" 
                                                              Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1432-.1064.2868-.2132.4233-.3241a.0746.0746 0 00.0235-.0814c3.9204 1.7933 8.18 1.7933 12.0614 0a.0738.0738 0 00.024.0821c.1367.111.2803.2177.4233.3241a.076.076 0 01-.0077.1277 12.2946 12.2946 0 01-1.8722.8923.077.077 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6066 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0551c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419z"/>
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>

                                                    <Button Grid.Column="1" Content="{Binding TextoBoton}" Background="{Binding ColorEstado}" 
                                                            Tag="{Binding}" Click="BtnAccionEvento_Click" 
                                                            Foreground="White" FontWeight="Bold" BorderThickness="0" FontSize="14">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>

                                                    <Button Grid.Column="2" Margin="5,0,0,0" Background="#33FF5656" BorderThickness="0" 
                                                            ToolTip="Eliminar Evento" Tag="{Binding}" Click="BtnEliminarEvento_Click">
                                                        <Path Fill="#FF5656" Stretch="Uniform" Width="18" Height="18" 
                                                              Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>

                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="VistaJugar" Margin="40,30,40,30" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Viewbox Grid.Row="0" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,50,20,20" MaxWidth="900">
                            <Grid x:Name="ContenedorNoticia" Height="260" Width="500" MouseEnter="DetenerCarrusel" MouseLeave="IniciarCarrusel">
                                <Border CornerRadius="15" BorderBrush="#33FFFFFF" BorderThickness="1">
                                    <Border.Background>
                                        <ImageBrush x:Name="ImgNoticiaFondoBrush" Stretch="UniformToFill" Opacity="0.5"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <BlurEffect Radius="20"/>
                                    </Border.Effect>
                                </Border>

                                <Border CornerRadius="15" BorderBrush="#33FFFFFF" BorderThickness="1" ClipToBounds="True">
                                    <Border.Background>
                                        <ImageBrush x:Name="ImgNoticiaBrush" Stretch="UniformToFill"/>
                                    </Border.Background>
                                    <Grid>
                                        <Border VerticalAlignment="Bottom" Height="180" CornerRadius="0,0,15,15">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#CC000000" Offset="0.4"/>
                                                    <GradientStop Color="#EE000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,30">
                                            <TextBlock x:Name="TxtTitulo" Text="{DynamicResource Play_NewsLoadingTitle}" FontSize="22" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TxtCuerpo" Text="{DynamicResource Play_NewsLoadingBody}" FontSize="12" Foreground="#FFEDEDED" FontWeight="SemiBold" Margin="0,2,0,10" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnNoticiaAccion" Style="{StaticResource PrimaryButton}" Content="{DynamicResource Play_NewsJoin}" Click="BtnNoticia_Click" Visibility="Visible" HorizontalAlignment="Left" Background="#5865F2" Foreground="White" FontWeight="Bold" FontSize="12" Padding="25,10" BorderThickness="0" Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
