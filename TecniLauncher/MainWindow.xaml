                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding IconoPath}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Nombre}" Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button x:Name="btnJugar" Content="{DynamicResource Play_BtnPlay}" Height="60" Width="320" Margin="0,10,0,0" Background="{StaticResource ColorAccent}" Foreground="White" FontSize="20" FontWeight="Black" BorderThickness="0" Click="BtnJugar_Click">
                                <Button.Effect>
                                    <DropShadowEffect Color="#4facfe" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                </Button.Effect>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="VistaPerfiles" Margin="40,50,40,30" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Profiles_Title}" Foreground="{StaticResource TextMain}" FontSize="24" FontWeight="Bold"/>
                            <Rectangle Height="2" Width="50" Fill="{StaticResource ColorAccent}" HorizontalAlignment="Left" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,70,0,0">
                            <Button Content="{DynamicResource Profiles_CreateNew}" Height="50" Background="{StaticResource ColorAccentDim}" Foreground="{StaticResource ColorAccent}" BorderBrush="{StaticResource ColorAccent}" BorderThickness="1" Margin="0,0,0,20" Click="AbrirCrearPerfil_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="+" FontSize="20" Margin="0,0,10,2"/>
                                                <TextBlock Text="{DynamicResource Profiles_CreateNew}" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="380" PanningMode="VerticalOnly">
                                <ItemsControl x:Name="listaPerfilesUI">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="80" Background="{StaticResource BgCard}" CornerRadius="10" Margin="0,0,5,10" Padding="20,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Ellipse Width="45" Height="45" Grid.Column="0" Margin="0,0,15,0" VerticalAlignment="Center">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding IconoPath}" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Nombre}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="18"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <Border Background="{StaticResource ColorAccentDim}" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding Version}" Foreground="{StaticResource ColorAccent}" FontSize="12" FontWeight="Bold"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding DetallesVisuales}" 
                                   Foreground="{StaticResource TextSub}" 
                                   FontSize="12" 
                                   VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="⚙️" Width="40" Height="40" Margin="0,0,5,0" Background="#22FFFFFF" Foreground="White" ToolTip="Editar" Tag="{Binding}" Click="BtnEditar_Click"/>
                                                        <Button Content="📂" Width="40" Height="40" Margin="0,0,5,0" Background="#33FFAA00" Foreground="#FFAA00" ToolTip="Carpeta" Tag="{Binding}" Click="BtnCarpeta_Click"/>
                                                        <Button Content="🗑️" Width="40" Height="40" Background="#33FF5656" Foreground="#FF5656" ToolTip="Eliminar" Tag="{Binding}" Click="BtnEliminar_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="VistaMods" Margin="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="40,40,40,20">
                            <TextBlock Text="{DynamicResource Mods_Title}" Foreground="{StaticResource TextMain}" FontSize="28" FontWeight="Bold"/>
                            <Rectangle Height="3" Width="60" Fill="#9b59b6" HorizontalAlignment="Left" Margin="0,5,0,0" RadiusX="1.5" RadiusY="1.5"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="40,0,40,20" Cursor="">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Mods_TargetProfile}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="2,0,0,5" FontWeight="SemiBold"/>
                                    <ComboBox x:Name="comboPerfilesMods" Height="45"
                          DisplayMemberPath="Nombre"
                          SelectionChanged="ComboPerfilesMods_SelectionChanged"
                          Background="#252525" BorderBrush="#444"
                          Foreground="White" FontSize="14" Padding="10,0">
                                        <ComboBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </ComboBox.Resources>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="15,0,0,0">
                                    <Border Background="#252525" CornerRadius="8" Padding="15,10" Margin="0,0,10,0" BorderBrush="#333" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Version: " Foreground="#888" FontSize="12"/>
                                            <TextBlock x:Name="txtModVersion" Text="0.00.0" Foreground="{StaticResource TextMain}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#252525" CornerRadius="8" Padding="15,10" BorderBrush="#333" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Loader: " Foreground="#888" FontSize="12"/>
                                            <TextBlock x:Name="txtModLoader" Text="Minecraft" Foreground="{StaticResource TextMain}" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="txtBuscadorMods" 
         Grid.Column="0" 
         Height="50" 
         Background="{StaticResource BgInput}" 
         Foreground="{StaticResource TextMain}" 
         FontSize="16" 
         Padding="20,14" 
         BorderThickness="0"
         VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Button Grid.Column="2" Content="{DynamicResource Mods_BtnSearch}"
                    Background="#9b59b6" Foreground="White"
                    FontWeight="Bold" FontSize="14"
                    Click="BtnBuscarOnline_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Effect>
                                        <DropShadowEffect Color="#9b59b6" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                    </Button.Effect>
                                </Button>
                            </Grid>

                            <Grid Grid.Row="2">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="TabOnlineBtn" IsChecked="True" GroupName="TabsMods" Checked="TabOnlineBtn_Checked">
                                        <RadioButton.Template>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="bdr" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,3" Padding="20,10">
                                                    <TextBlock x:Name="txt" Text="{DynamicResource Mods_TabOnline}" Foreground="#8c9bb0" FontSize="15" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#9b59b6"/>
                                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bdr" Property="Background" Value="#11FFFFFF"/>
                                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RadioButton.Template>
                                    </RadioButton>

                                    <RadioButton x:Name="TabInstaladosBtn" GroupName="TabsMods" Checked="TabInstaladosBtn_Checked">
                                        <RadioButton.Template>
                                            <ControlTemplate TargetType="RadioButton">
                                                <Border x:Name="bdr" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,3" Padding="20,10">
                                                    <TextBlock x:Name="txt" Text="{DynamicResource Mods_TabInstalled}" Foreground="#8c9bb0" FontSize="15" FontWeight="SemiBold"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#9b59b6"/>
                                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bdr" Property="Background" Value="#11FFFFFF"/>
                                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RadioButton.Template>
                                    </RadioButton>
                                </StackPanel>

                                <Rectangle Height="1" Fill="#22FFFFFF" VerticalAlignment="Bottom"/>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,10,0,0">

                                <Grid x:Name="PanelOnline" Visibility="Visible">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <Border Background="#08FFFFFF" CornerRadius="12" Padding="15">
                                            <ListBox x:Name="listaModsGestor" 
         Background="Transparent" 
         BorderThickness="0"
         PreviewMouseWheel="listaMods_PreviewMouseWheel"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
         ScrollViewer.CanContentScroll="False">

                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border x:Name="ContenedorFila" Background="#1E2328" CornerRadius="10" Padding="15" BorderThickness="1" BorderBrush="#33FFFFFF">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="0" CornerRadius="8" Width="50" Height="50" ClipToBounds="True" Background="#111" Margin="0,0,15,0" VerticalAlignment="Center">
                                                                    <Image Source="{Binding icon_url}" Stretch="UniformToFill"/>
                                                                </Border>

                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,15,0">
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                                        <TextBlock Text="{Binding title}" FontWeight="Bold" FontSize="15" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                                                        <Border x:Name="BadgeRecomendado" Background="#33FFD700" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                                                            <TextBlock x:Name="Mods_Recommended" Text="{DynamicResource Mods_Recommended}" Foreground="#FFD700" FontSize="10" FontWeight="Bold"/>
                                                                        </Border>
                                                                    </StackPanel>

                                                                    <TextBlock Text="{Binding author}" Foreground="#8c9bb0" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                                    <TextBlock Text="{Binding description}" FontSize="12" Foreground="#AAA" TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                                                                </StackPanel>

                                                                <Button Grid.Column="2" x:Name="Mods_verVersiones" Content="{DynamicResource Mods_verVersiones}" Tag="{Binding}" Click="BtnAccionMod_Click"
                            Height="36" Padding="15,0" Background="{StaticResource ColorAccent}" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center">
                                                                    <Button.Resources>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="CornerRadius" Value="8"/>
                                                                        </Style>
                                                                    </Button.Resources>
                                                                </Button>
                                                            </Grid>
                                                        </Border>

                                                        <DataTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ContenedorFila" Property="Background" Value="#252A30"/>
                                                            </Trigger>

                                                            <DataTrigger Binding="{Binding esRecomendado}" Value="True">
                                                                <Setter TargetName="BadgeRecomendado" Property="Visibility" Value="Visible"/>
                                                                <Setter TargetName="ContenedorFila" Property="BorderBrush" Value="#FFD700"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </ScrollViewer>
                                </Grid>

                                <Grid x:Name="PanelInstalados" Visibility="Collapsed">
                                    <Border Background="#08FFFFFF" CornerRadius="12" Padding="10">
                                        <ListBox x:Name="listaModsInstaladosGestor" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="bdr" Background="#1E2328" CornerRadius="10" Padding="15,10" Margin="0,0,0,8" BorderThickness="1" BorderBrush="#33FFFFFF">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bdr" Property="Background" Value="#252A30"/>
                                                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#ff4a4a"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" CornerRadius="6" Width="36" Height="36" Background="#111" Margin="0,0,15,0">
                                                            <Image Source="{Binding icon_url}" Stretch="Uniform" Margin="5"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding title}" FontWeight="Bold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding description}" Foreground="#8c9bb0" FontSize="11" Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Button Grid.Column="2" x:Name="Mods_Delete" Content="{DynamicResource Mods_Delete}" Tag="{Binding}" Click="BtnAccionMod_Click" 
    Height="32" Padding="15,0" Background="#33ff4a4a" Foreground="#ff4a4a" BorderBrush="#ff4a4a" BorderThickness="1"
    FontSize="11" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="6"/>
                                                                </Style>
                                                            </Button.Resources>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid x:Name="OverlayVersiones" Visibility="Collapsed" Background="#CC000000"
IsHitTestVisible="True" Panel.ZIndex="999">
                        <Border Width="600" Height="550"
      Background="{StaticResource BgSidebar}"
      CornerRadius="16"
      BorderBrush="{StaticResource ColorAccent}"
      BorderThickness="1"
      VerticalAlignment="Center"
      HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.7"/>
                            </Border.Effect>
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0">
                                    <TextBlock x:Name="txtNombreModVersiones" Text="Versiones Disponibles"
                     FontSize="24" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock x:Name="Mods_DesDes" Text="{DynamicResource Mods_DesDes}"
                     FontSize="14" Foreground="#AAA" Margin="0,5,0,20"/>
                                    <Rectangle Height="1" Fill="#333" Margin="0,0,0,15"/>
                                </StackPanel>

                                <ListView x:Name="listaArchivosVersion" Grid.Row="1"
                Background="Transparent" BorderThickness="0"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border Background="#1E2328" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="Transparent">
                                                            <ContentPresenter/>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#252A30"/>
                                                                            <Setter Property="BorderBrush" Value="{StaticResource ColorAccent}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding NombreArchivo}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <Border Background="#222" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding Tipo}" Foreground="{Binding ColorTipo}" FontSize="11" FontWeight="Bold"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Fecha}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Button Grid.Column="1" x:Name="Mods_Install" Content="{DynamicResource Mods_Install}" Width="100" Height="36"
                              Background="#22FFFFFF" Foreground="White" BorderThickness="0"
                              FontSize="11" FontWeight="Bold"
                              Tag="{Binding}" Click="BtnInstalarVersion_Click">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="6"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Button Grid.Row="2" x:Name="Mods_cerrar" Content="{DynamicResource Mods_cerrar}" Margin="0,20,0,0" Height="45"
              Background="#333" Foreground="White" FontWeight="Bold"
              Click="BtnCerrarVersiones_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="VistaModpacks" Visibility="Collapsed" Margin="40,30,40,30" IsVisibleChanged="VistaModpacks_IsVisibleChanged">

                        <Grid x:Name="PanelBusquedaModpacks" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="{DynamicResource ModPack_Title}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                <Rectangle Height="3" Width="60" Fill="#4facfe" HorizontalAlignment="Left" Margin="0,5,0,15" RadiusX="1.5" RadiusY="1.5"/>
                                <TextBlock Text="{DynamicResource ModPack_SubTitle}" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#222222" CornerRadius="8" BorderBrush="#444444" BorderThickness="1">
                                        <TextBox x:Name="txtBuscadorModpacks" Height="40" FontSize="16" Foreground="White" Background="Transparent" BorderThickness="0" Padding="15,8" VerticalContentAlignment="Center" KeyDown="TxtBuscadorModpacks_KeyDown"/>
                                    </Border>
                                    <Button x:Name="btnBuscarModpacks" Grid.Column="1" Content="BUSCAR" Width="120" Margin="10,0,0,0" Background="#9b59b6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnBuscarModpacks_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="txtCargandoModpacks" Grid.Row="1" Text="Buscando modpacks en Modrinth..." Foreground="#4facfe" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Visibility="Collapsed"/>

                            <ListBox x:Name="listaModpacksUI" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="300" Height="160" Background="#1E2328" CornerRadius="10" Margin="5" Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="75"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border CornerRadius="8" Width="65" Height="65" VerticalAlignment="Top" HorizontalAlignment="Left">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding IconoUrl}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                                    <TextBlock Text="{Binding Titulo}" Foreground="White" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,5">
                                                        <TextBlock Text="Por " Foreground="#666666" FontSize="12"/>
                                                        <TextBlock Text="{Binding Autor}" Foreground="#888888" FontWeight="Bold" FontSize="12"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Descripcion}" Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap" MaxHeight="45" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"  Style="{StaticResource PrimaryButton}" Content="VER DETALLES" VerticalAlignment="Bottom" HorizontalAlignment="Right" Padding="15,5" Background="#4facfe" Foreground="White" FontWeight="Bold" FontSize="11" BorderThickness="0" Cursor="Hand" Click="BtnVerModpack_Click" Tag="{Binding}">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="6"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid x:Name="PanelDetalleModpack" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0" Content="← Volver a la búsqueda" HorizontalAlignment="Left" Background="Transparent" Foreground="#4facfe" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="BtnVolverModpacks_Click"/>

                            <Grid Grid.Row="1" Margin="0,20,0,20">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border CornerRadius="12" Width="90" Height="90" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <ImageBrush x:Name="imgDetalleModpack" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,20,0">
                                    <TextBlock x:Name="txtDetalleTitulo" Text="Título del Modpack" Foreground="White" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="txtDetalleAutor" Text="Por Autor" Foreground="#AAAAAA" FontSize="14" Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ComboBox x:Name="comboVersionesModpack" Width="160" Margin="0,0,10,0" Height="45" 
                  VerticalContentAlignment="Center" Padding="10,0" DisplayMemberPath="NombreAgradable"/>

                                    <Button x:Name="btnInstalarModpack" Content="INSTALAR" Background="#27ae60" Foreground="White" FontWeight="Bold" FontSize="14" Padding="20,0" Height="45" BorderThickness="0" Cursor="Hand" Click="BtnInstalarModpack_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <StackPanel x:Name="PanelProgresoDescarga" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,25,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="txtEstadoDescarga" Text="Preparando descarga..." Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5" FontWeight="Bold"/>
                                    <ProgressBar x:Name="barraDescarga" Height="15" Minimum="0" Maximum="100" Value="0" Foreground="#27ae60" Background="#222222" BorderThickness="0">
                                        <ProgressBar.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="7"/>
                                            </Style>
                                        </ProgressBar.Resources>
                                    </ProgressBar>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2" Background="#1A1E2328" CornerRadius="10" Padding="20">
                                <md:MarkdownScrollViewer x:Name="mdDetalleDescripcion" Foreground="#DDDDDD" Markdown="Descripción completa..."/>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="VistaAjustes" Margin="0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">

                            <StackPanel Margin="40" MaxWidth="900" HorizontalAlignment="Center">

                                <StackPanel Margin="0,0,0,30">
                                    <TextBlock Text="{DynamicResource Settings_Title}" Foreground="{StaticResource TextMain}" FontSize="28" FontWeight="Bold"/>
                                    <Rectangle Height="3" Width="60" Fill="{StaticResource ColorAccent}" HorizontalAlignment="Left" Margin="0,5,0,0" RadiusX="1.5" RadiusY="1.5"/>
                                </StackPanel>

                                <TextBlock Text="{DynamicResource Settings_Language}" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="14" Margin="5,0,0,8"/>
                                <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,0,25" BorderThickness="1" BorderBrush="#22FFFFFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Settings_LanguageDesc}" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{DynamicResource Settings_LanguageSub}" Foreground="{StaticResource TextSub}" FontSize="11"/>
                                        </StackPanel>

                                        <ComboBox x:Name="comboIdiomas" Grid.Column="1" Width="200" Height="35" SelectionChanged="ComboIdiomas_SelectionChanged"
                              Background="#252525" BorderBrush="#444" Foreground="White" VerticalContentAlignment="Center" Padding="10,0">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                </Style>
                                            </ComboBox.Resources>
                                            <ComboBoxItem Content="Español" Tag="es-ES" IsSelected="True"/>
                                            <ComboBoxItem Content="English" Tag="en-US"/>
                                            <ComboBoxItem Content="Português (Brasil)" Tag="pt-BR"/>
                                        </ComboBox>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{DynamicResource Settings_General}" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="14" Margin="5,0,0,8"/>
                                <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,0,25" BorderThickness="1" BorderBrush="#22FFFFFF">
                                    <StackPanel>
                                        <CheckBox x:Name="chkOcultarLauncher" Margin="0,5" Cursor="Hand" Foreground="White">
                                            <StackPanel Margin="10,-2,0,0">
                                                <TextBlock Text="{DynamicResource Settings_HideLauncher}" FontWeight="Bold" Foreground="{StaticResource TextMain}" FontSize="14"/>
                                                <TextBlock Text="{DynamicResource Settings_HideLauncherDesc}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </CheckBox>

                                        <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,15"/>

                                        <CheckBox x:Name="chkSnapshots" Click="ChkSnapshots_Click" Cursor="Hand" Foreground="White">
                                            <StackPanel Margin="10,-2,0,0">
                                                <TextBlock Text="{DynamicResource Settings_ShowSnapshots}" FontWeight="Bold" Foreground="{StaticResource TextMain}" FontSize="14"/>
                                                <TextBlock Text="{DynamicResource Settings_ShowSnapshotsDesc}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{DynamicResource Settings_Video}" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="14" Margin="5,0,0,8"/>
                                <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,0,25" BorderThickness="1" BorderBrush="#22FFFFFF">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource Settings_Resolution}" FontWeight="Bold" Foreground="{StaticResource TextMain}" FontSize="14"/>
                                                <TextBlock Text="{DynamicResource Settings_ResolutionDesc}" Foreground="{StaticResource TextSub}" FontSize="12"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{DynamicResource Settings_Width}" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                                <TextBox x:Name="txtResAncho" Width="60" Height="30" Text="854" Background="#252525" Foreground="White" BorderBrush="#444"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="0"
                                     TextChanged="TxtRes_TextChanged" PreviewTextInput="SoloNumeros_PreviewTextInput">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="5"/>
                                                        </Style>
                                                    </TextBox.Resources>
                                                </TextBox>

                                                <TextBlock Text="x" Foreground="{StaticResource ColorAccent}" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>

                                                <TextBlock Text="{DynamicResource Settings_Height}" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                                                <TextBox x:Name="txtResAlto" Width="60" Height="30" Text="480" Background="#252525" Foreground="White" BorderBrush="#444"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="0"
                                     TextChanged="TxtRes_TextChanged" PreviewTextInput="SoloNumeros_PreviewTextInput">
                                                    <TextBox.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="5"/>
                                                        </Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </StackPanel>
                                        </Grid>

                                        <Rectangle Height="1" Fill="#22FFFFFF" Margin="0,5,0,15"/>

                                        <CheckBox x:Name="chkFullscreen" Click="ChkFullscreen_Click" Cursor="Hand" Foreground="White">
                                            <StackPanel Margin="10,-2,0,0">
                                                <TextBlock Text="{DynamicResource Settings_Fullscreen}" FontWeight="Bold" Foreground="{StaticResource TextMain}" FontSize="14"/>
                                                <TextBlock Text="{DynamicResource Settings_FullscreenDesc}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{DynamicResource Settings_Customization}" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="14" Margin="5,0,0,8"/>
                                <Border Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,0,30" BorderThickness="1" BorderBrush="#22FFFFFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                            <TextBlock Text="{DynamicResource Settings_SkinTitle}" FontWeight="Bold" Foreground="{StaticResource TextMain}" FontSize="15"/>
                                            <TextBlock Text="{DynamicResource Settings_SkinDesc}" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,20" TextWrapping="Wrap"/>

                                            <Border x:Name="ZonaSkin" Height="100" CornerRadius="10" Cursor="Hand" Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" MouseLeftButtonDown="ZonaSkin_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ColorAccent}"/>
                                                                <Setter Property="Background" Value="#1A4FACFE"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="☁️" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                        <TextBlock Text="{DynamicResource Settings_UploadSkin}" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource Settings_ElySub}" Foreground="#888" FontSize="11" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Button Margin="0,15,0,0" Height="40" Background="#22FF5656" Foreground="#FF5656" BorderThickness="1" BorderBrush="#44FF5656" Click="BtnBorrarSkin_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="↻ " FontWeight="Bold" Margin="0,0,5,0"/>
                                                                <TextBlock Text="{DynamicResource Settings_DeleteSkin}" FontWeight="SemiBold" FontSize="12"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bdr" Property="Opacity" Value="0.8"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock x:Name="TxtVersionAjustes" Text="TecniLauncher v..." Foreground="#444" HorizontalAlignment="Center" FontSize="12" Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <Grid x:Name="GridLogin" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#CC000000">
                    <Border Width="380" MinHeight="450" Background="{StaticResource BgSidebar}" CornerRadius="15" BorderBrush="{StaticResource ColorAccent}" BorderThickness="1" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="#4facfe" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                        </Border.Effect>
                        <Grid Margin="40">

                            <StackPanel x:Name="PanelLoginPrincipal" VerticalAlignment="Center" Visibility="Visible">
                                <TextBlock Text="{DynamicResource Login_Welcome}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                                <Button x:Name="btnMicrosoft" Content="{DynamicResource Login_Microsoft}" Height="50" Background="#005da6" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnMicrosoft_Click" Margin="0,0,0,10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Grid Width="16" Height="16" Margin="0,0,10,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <Rectangle Fill="White" Margin="1"/>
                                                        <Rectangle Fill="White" Grid.Column="1" Margin="1"/>
                                                        <Rectangle Fill="White" Grid.Row="1" Margin="1"/>
                                                        <Rectangle Fill="White" Grid.Column="1" Grid.Row="1" Margin="1"/>
                                                    </Grid>
                                                    <ContentPresenter/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="btnAbrirElyBy" Content="{DynamicResource CuentaEly}" Height="50" Background="#2c3e50" Foreground="White" FontWeight="Bold" FontSize="14" Click="BtnAbrirElyBy_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Grid Margin="0,20,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Height="1" Fill="#333"/>
                                    <TextBlock Text="{DynamicResource Login_OfflineTitle}" Grid.Column="1" Foreground="#666" FontSize="10" Margin="10,0" VerticalAlignment="Center"/>
                                    <Rectangle Grid.Column="2" Height="1" Fill="#333"/>
                                </Grid>

                                <TextBlock Text="{DynamicResource Login_Username}" Foreground="{StaticResource TextSub}" Margin="5,0,0,5" FontSize="12"/>
                                <TextBox x:Name="txtOfflineName" Height="45" Background="{StaticResource BgInput}" Foreground="White" BorderBrush="#444" Padding="15,12" FontSize="14" Text="{DynamicResource Login_PlayerPlaceholder}">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Grid Margin="0,25,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{DynamicResource Login_Enter}" Grid.Column="0" Height="50" Background="{StaticResource ColorAccent}" Foreground="White" FontWeight="Bold" Click="BtnEntrarLauncher_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="X" Grid.Column="2" Height="50" Background="#333" Foreground="White" FontWeight="Bold" Click="BtnCerrarLogin_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="PanelLoginElyBy" VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock Text="{DynamicResource CuentaEly_iniciar}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{DynamicResource CuentaEly_Creden}" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                                <TextBlock Text="{DynamicResource CuentaEly_Correo}" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,5"/>
                                <TextBox x:Name="txtUsuarioElyBy" Height="45" Background="{StaticResource BgInput}" Foreground="White" BorderBrush="#444" BorderThickness="1" Padding="15,0" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,0,15">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <TextBlock Text="{DynamicResource CuentaEly_Contra}" Foreground="{StaticResource TextSub}" FontSize="12" FontWeight="SemiBold" Margin="5,0,0,5"/>
                                <PasswordBox x:Name="txtPasswordElyBy" Height="45" Background="{StaticResource BgInput}" Foreground="White" BorderBrush="#444" BorderThickness="1" Padding="15,0" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,0,20">
                                    <PasswordBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </PasswordBox.Resources>
                                </PasswordBox>

                                <TextBlock x:Name="txtEstadoElyBy" Text="" Foreground="#FF5656" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed"/>

                                <Button x:Name="btnLoginElyBy" Content="{DynamicResource CuentaEly_Entrar}" Height="50" Background="{StaticResource ColorAccent}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnLoginElyBy_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button x:Name="btnCancelarElyBy" Content="{DynamicResource CuentaEly_atras}" Height="30" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Cursor="Hand" Margin="0,15,0,0" Click="BtnCancelarElyBy_Click"/>
                            </StackPanel>

                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="GridCrearPerfil" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#CC000000">
                    <Border Width="420" VerticalAlignment="Center" Background="{StaticResource BgSidebar}" CornerRadius="15" BorderBrush="{StaticResource ColorAccent}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.6"/>
                        </Border.Effect>

                        <StackPanel Margin="30,25">
                            <TextBlock Text="{DynamicResource Config_Title}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <TextBlock Text="{DynamicResource Config_Name}" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="11"/>
                            <TextBox x:Name="txtNombrePerfil" Height="38" Background="{StaticResource BgInput}" Foreground="White" BorderThickness="0" Padding="10,8" FontSize="14"/>

                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource Config_Loader}" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="11"/>
                                    <ComboBox x:Name="comboLoader" Height="38" SelectionChanged="ComboLoader_SelectionChanged">
                                        <ComboBoxItem Content="Vanilla" IsSelected="True"/>
                                        <ComboBoxItem Content="Forge"/>
                                        <ComboBoxItem Content="Fabric"/>
                                        <ComboBoxItem Content="NeoForge"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{DynamicResource Config_Version}" Foreground="{StaticResource TextSub}" Margin="0,0,0,5" FontSize="11"/>
                                    <ComboBox x:Name="comboVersiones" Height="38" SelectionChanged="ComboVersiones_SelectionChanged"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="lblLoaderVersion" Text="{DynamicResource Config_LoaderVer}" Foreground="#888" Margin="0,10,0,5" FontSize="11" Visibility="Collapsed"/>
                            <ComboBox x:Name="comboLoaderVersion" IsEnabled="False" Visibility="Collapsed" Height="35" Background="#202020" Foreground="White" Padding="10,5"/>

                            <TextBlock Text="{DynamicResource Config_Ram}" Foreground="{StaticResource TextSub}" Margin="0,15,0,5" FontSize="11"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="sliderRam" Grid.Column="0" Minimum="1" Maximum="16" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SliderRam_ValueChanged"/>
                                <TextBlock x:Name="lblRam" Grid.Column="1" Text="2 GB" Foreground="{StaticResource ColorAccent}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="{DynamicResource Config_Icon}" Foreground="{StaticResource TextSub}" Margin="0,15,0,5" FontSize="11"/>

                            <ListBox x:Name="listaIconos" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Width="350" HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="border" CornerRadius="20" BorderThickness="2" BorderBrush="Transparent" Margin="4">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ColorAccent}"/>
                                                            <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBoxItem Tag="icon1.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon1.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon2.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon2.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon3.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon3.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon4.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon4.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon5.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon5.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon6.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon6.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon7.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon7.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon8.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon8.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon9.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon9.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                                <ListBoxItem Tag="icon10.png">
                                    <Ellipse Width="32" Height="32">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Resources/Icons/icon10.png"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </ListBoxItem>
                            </ListBox>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="{DynamicResource Btn_Save}" Height="42" Background="{StaticResource ColorAccent}" Foreground="White" FontWeight="Bold" Click="BtnGuardarPerfil_Click"/>
                                <Button Grid.Column="2" Content="{DynamicResource Btn_Cancel}" Height="42" Background="#333" Foreground="White" FontWeight="Bold" Click="BtnCancelarPerfil_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="PanelCarga" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#D9000000" Panel.ZIndex="999">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                        <ProgressBar x:Name="barraCarga"
                         IsIndeterminate="True" 
                         Width="300" 
                         Height="10" 
                         BorderThickness="0"
                         Background="#33FFFFFF"
                         Foreground="#3498db" 
                         Margin="0,0,0,20">
                            <ProgressBar.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </ProgressBar.Resources>
                        </ProgressBar>

                        <TextBlock x:Name="txtEstadoCarga" 
                       Text="{DynamicResource Msg_Loading}" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>